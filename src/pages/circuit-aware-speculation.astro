---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = 'Acceptance-Aware Speculation';
const pageDescription =
	'A mechanistic study of speculative decoding: a free, timing-based rule that guesses a smart number of draft tokens beats the best fixed count by +11.2% while cutting wasted compute by 62%.';

const headline = [
	{ value: '+11.2%', label: 'Efficiency over the best fixed draft length', tone: 'win' },
	{ value: '-62%', label: 'Wasted draft tokens per accepted token', tone: 'win' },
	{ value: '< 1 / 2000', label: 'Probability the gain is noise (322 held-out prompts)', tone: 'win' },
	{ value: '302k', label: 'Labeled tokens replayed from locked, checksummed traces', tone: 'neutral' },
];

const questions = [
	{
		id: 'RQ2',
		question: 'Can we pick a smart number of tokens to draft each round instead of a fixed number?',
		answer: 'Yes',
		tone: 'yes',
		why: '+11.2% efficiency, 62% less waste; holds on fresh held-out data (+11.3% → +11.2%).',
	},
	{
		id: 'RQ3',
		question: 'Do topic-specialist small draft models help?',
		answer: 'No',
		tone: 'no',
		why: 'Specialists tie or lose to a same-size generalist — even on their own topic. The optimal router would pick the generalist everywhere.',
	},
	{
		id: 'RQ1',
		question: 'Does combining both ideas beat the best fixed setup?',
		answer: 'Collapses to RQ2',
		tone: 'shrink',
		why: 'Specialists add nothing (RQ3), so the interesting lever is adaptive draft length alone.',
	},
];

const rq2Rows = [
	{ rule: 'Best fixed count (8)', round: '4.32', waste: '1.08', eff: '2.40', highlight: false },
	{ rule: 'Adaptive rule (ours)', round: '3.85', waste: '0.41', eff: '2.67 (+11.2%)', highlight: true },
	{ rule: 'Oracle hindsight (ceiling)', round: '4.32', waste: '0.02', eff: '3.23', highlight: false },
];

const specialistRows = [
	{ model: 'general 0.5B', chat: '0.738', code: '0.898', math: '0.910', sum: '0.672', best: false },
	{ model: 'Coder 0.5B', chat: '0.675', code: '0.899', math: '0.877', sum: '0.603', best: false },
	{ model: 'general 1.5B', chat: '0.789', code: '0.917', math: '0.928', sum: '0.736', best: true },
	{ model: 'Math 1.5B', chat: '0.662', code: '0.862', math: '0.919', sum: '0.554', best: false },
	{ model: 'Coder 1.5B', chat: '0.753', code: '0.917', math: '0.917', sum: '0.695', best: false },
];

const methodology = [
	{
		title: 'A verified lossless engine',
		body: 'An exact target–draft decoding engine, proven to emit the same tokens the 7B target would produce alone (73 of 73 equivalence checks passed in full precision). Speed is never traded for quality.',
	},
	{
		title: 'Sealed, checksummed traces',
		body: '644 prompts across code, math, chat, and summarization, run under 8 configurations, yielding ~302,000 labeled tokens saved as immutable, checksummed artifacts.',
	},
	{
		title: 'Offline replay, no re-runs',
		body: "Because the target's choice was recorded at every position, any draft-length policy can be evaluated by replaying the saved data — no model re-execution, fully reproducible.",
	},
	{
		title: 'Fair model comparison',
		body: 'Every candidate draft model is scored against the same target output, so specialist-vs-generalist comparisons are apples to apples.',
	},
	{
		title: 'Prompt-grouped splits',
		body: 'Data is split by prompt, never by token, to prevent adjacent-token leakage. The rule is tuned on a dev set, frozen, then tested on a fresh exam set.',
	},
	{
		title: 'Scripts-only, failures logged',
		body: 'Every reported number is generated by a versioned script from locked artifacts — never hand-entered — and negative results are preserved in a claims ledger.',
	},
];

const supporting = [
	{
		kind: 'positive',
		title: 'The acceptance atlas',
		body: 'Across 302,464 tokens, acceptance rate ranges from 0.52 to 0.88 depending on token type. Structural tokens (code symbols, operators, numbers) are easy (~0.85–0.88); meaning-heavy tokens (names, reasoning turns) are hard (~0.58–0.67). This pattern is the reason the adaptive rule works — and it depends on no timing at all.',
	},
	{
		kind: 'negative',
		title: 'Cheap signals are enough',
		body: "Free signals the draft model already emits predict acceptance well (AUROC ≈ 0.87). Probing the model's internal hidden states peaks lower (0.803) and adds at most +0.006 on top. A clean no-extra-benefit result for this model pair.",
	},
	{
		kind: 'context',
		title: 'Honest about wall-clock',
		body: 'The research harness launches the draft model one token at a time (~24 ms/token overhead), making it look nearly as slow as a full target verify (~30 ms). On this setup the speedup looks like ~5%, but the same traces imply 25–46% on a serving-grade fused, graph-captured draft. So we report efficiency, and say so plainly.',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${pageTitle} | ${SITE_TITLE}`} description={pageDescription} />
	</head>
	<body>
		<Header />
		<main class="home cas">
			<section class="intro">
				<p class="eyebrow">Research · Speculative decoding · Mechanistic interpretability</p>
				<h1 class="about-heading">Acceptance-Aware Speculation</h1>
				<p class="lede">
					Where does information about future token rejection live inside a speculative draft model —
					and can it steer compute-optimal decoding? A simple, free rule that reads how unsure the draft
					model is <em>right now</em> beats the best fixed draft length by <strong>+11.2%</strong> while
					cutting wasted compute by <strong>62%</strong>. Two fancier ideas were tested and shown not to help.
				</p>
				<div class="intro-signals" aria-label="Study signals">
					<span>Qwen2.5-7B target</span>
					<span>Qwen2.5 0.5B / 1.5B draft</span>
					<span>Lossless decoding</span>
					<span>Prompt-grouped splits</span>
					<span>Scripts-only, checksummed</span>
				</div>
				<div class="profile-links" aria-label="Links">
					<a href="https://github.com/Raghavan1988">GitHub</a>
				</div>
			</section>

			<section class="cas-stats" aria-label="Headline results">
				{
					headline.map((stat) => (
						<div class={`cas-stat tone-${stat.tone}`}>
							<span class="cas-stat-value">{stat.value}</span>
							<span class="cas-stat-label">{stat.label}</span>
						</div>
					))
				}
			</section>

			<section class="cas-block">
				<h2>The idea, in plain English</h2>
				<p>
					Big language models are slow because they emit <strong>one token at a time</strong>, each
					requiring a full forward pass. <strong>Speculative decoding</strong> speeds this up with two
					models: a small, fast draft model guesses the next few tokens, and the big, accurate target
					model checks all the guesses <strong>at once</strong>, in a single pass. Correct guesses are
					kept for free; wrong guesses are discarded. Crucially, the final text is <em>exactly</em> what
					the target would have written alone — quality is never traded for speed.
				</p>
				<p>The study asks three questions:</p>
				<div class="cas-questions">
					{
						questions.map((q) => (
							<article class={`cas-q tone-${q.tone}`}>
								<div class="cas-q-head">
									<span class="cas-q-id">{q.id}</span>
									<span class="cas-q-answer">{q.answer}</span>
								</div>
								<p class="cas-q-question">{q.question}</p>
								<p class="cas-q-why">{q.why}</p>
							</article>
						))
					}
				</div>
			</section>

			<section class="cas-block">
				<h2>Methodology</h2>
				<p>
					The whole study is built to be reproducible and leakage-safe: an exact engine, sealed data,
					offline replay, and a strict rule that no reported number is ever typed by hand.
				</p>
				<div class="cas-method-grid">
					{
						methodology.map((item) => (
							<article class="cas-method">
								<h3>{item.title}</h3>
								<p>{item.body}</p>
							</article>
						))
					}
				</div>
			</section>

			<section class="cas-block">
				<h2>Main finding — a smart draft length beats the best fixed one</h2>
				<p>
					Replaying draft-length policies on the frozen exam set, the adaptive rule beats the best fixed
					count by <strong>+11.2%</strong> efficiency (useful tokens per unit of work). The 95% interval
					is <strong>+10.3% to +12.1%</strong> across 322 exam prompts, and the chance of no real gain is
					below 1 in 2,000. It wins on <em>every</em> topic.
				</p>
				<div class="cas-table-wrap">
					<table class="cas-table">
						<thead>
							<tr>
								<th scope="col">Rule (fresh exam set)</th>
								<th scope="col">Tokens / round</th>
								<th scope="col">Wasted per kept token</th>
								<th scope="col">Efficiency</th>
							</tr>
						</thead>
						<tbody>
							{
								rq2Rows.map((row) => (
									<tr class={row.highlight ? 'is-highlight' : ''}>
										<th scope="row">{row.rule}</th>
										<td>{row.round}</td>
										<td>{row.waste}</td>
										<td>{row.eff}</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>
				<p class="cas-note">
					<strong>Why it works — timing, not learning.</strong> Bandit-style "try and learn" methods just
					settle on the best fixed count and cannot beat it. The adaptive rule wins because it reads the
					draft model's uncertainty <em>before each round</em>: when the draft is confident, its guesses
					are accepted 97% of the time; when unsure, only 16%. A simple 4-option menu keeps 98% of the
					value, so it is easy to ship.
				</p>
			</section>

			<section class="cas-block">
				<h2>A tested dead end — specialists don't beat a generalist</h2>
				<p>
					Five draft models were scored across four topics, each against the same target output.
					Same-size code specialists merely <strong>tie</strong> the generalist on code; the math
					specialist is <strong>worse</strong> than the generalist even on math. The best possible router
					would pick the general 1.5B everywhere.
				</p>
				<div class="cas-table-wrap">
					<table class="cas-table">
						<thead>
							<tr>
								<th scope="col">Draft model</th>
								<th scope="col">chat</th>
								<th scope="col">code</th>
								<th scope="col">math</th>
								<th scope="col">summaries</th>
							</tr>
						</thead>
						<tbody>
							{
								specialistRows.map((row) => (
									<tr class={row.best ? 'is-highlight' : ''}>
										<th scope="row">{row.model}</th>
										<td>{row.chat}</td>
										<td>{row.code}</td>
										<td>{row.math}</td>
										<td>{row.sum}</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>
				<p class="cas-note">
					Acceptance is about how well the draft matches the <em>target's own style</em>. A same-family
					generalist matches a generalist target better than a narrow expert does. <strong>Bigger helps;
					specializing doesn't.</strong>
				</p>
			</section>

			<section class="cas-block">
				<h2>Supporting findings</h2>
				<div class="cas-support-grid">
					{
						supporting.map((item) => (
							<article class={`cas-support kind-${item.kind}`}>
								<span class="cas-support-tag">
									{item.kind === 'positive'
										? 'Positive result'
										: item.kind === 'negative'
											? 'Clean negative'
											: 'Systems context'}
								</span>
								<h3>{item.title}</h3>
								<p>{item.body}</p>
							</article>
						))
					}
				</div>
			</section>

			<section class="cas-block cas-takeaway">
				<h2>What it means</h2>
				<ul>
					<li>
						<strong>The win.</strong> Easy and hard tokens follow a clear pattern (the atlas), and a free
						rule that reads a cheap uncertainty signal turns that pattern into a real, statistically solid
						efficiency gain that transfers to fresh data without re-tuning.
					</li>
					<li>
						<strong>Two dead ends, honestly reported.</strong> Digging into internal hidden states doesn't
						beat free signals, and topic specialists don't beat a same-size generalist. Both save future
						researchers wasted effort and point to the real levers: model <em>size</em>, matching the
						<em> target's style</em>, and adapting the <em>draft length</em>.
					</li>
					<li>
						<strong>Honest about speed.</strong> Efficiency gains are real today; raw wall-clock gains wait
						on serving-grade engineering — and the same traces measure exactly how much is waiting (25–46%).
					</li>
				</ul>
			</section>
		</main>
		<Footer fine />
	</body>
</html>

<style>
	.cas h2 {
		font-size: clamp(1.35rem, 2.4vw, 1.85rem);
		margin: 0 0 0.6rem;
	}
	.cas-block {
		border-bottom: 1px solid var(--line);
		padding: 1.6rem 0;
	}
	.cas-block > p {
		color: var(--muted);
		font-size: clamp(1rem, 1.5vw, 1.12rem);
		line-height: 1.55;
		max-width: 860px;
		margin: 0 0 0.75rem;
	}
	.cas .lede em {
		font-style: italic;
	}

	.cas-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 0.85rem;
		padding: 1.5rem 0 0.4rem;
	}
	.cas-stat {
		border: 1px solid var(--line);
		border-radius: 14px;
		padding: 1rem 1.1rem;
		background: rgba(255, 253, 248, 0.6);
	}
	.cas-stat.tone-win {
		border-color: rgba(20, 130, 90, 0.35);
		background: rgba(20, 150, 100, 0.07);
	}
	.cas-stat-value {
		display: block;
		font-size: clamp(1.6rem, 3.2vw, 2.3rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--ink);
	}
	.cas-stat.tone-win .cas-stat-value {
		color: #0f7a52;
	}
	.cas-stat-label {
		display: block;
		margin-top: 0.35rem;
		color: var(--muted);
		font-size: 0.86rem;
		line-height: 1.35;
	}

	.cas-questions {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 0.85rem;
		margin-top: 0.9rem;
	}
	.cas-q {
		border: 1px solid var(--line);
		border-left: 4px solid var(--line);
		border-radius: 12px;
		padding: 0.95rem 1rem;
		background: rgba(255, 253, 248, 0.6);
	}
	.cas-q.tone-yes {
		border-left-color: #0f7a52;
	}
	.cas-q.tone-no {
		border-left-color: #b4462f;
	}
	.cas-q.tone-shrink {
		border-left-color: var(--orange);
	}
	.cas-q-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		margin-bottom: 0.4rem;
	}
	.cas-q-id {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.74rem;
		font-weight: 700;
		color: var(--muted);
		text-transform: uppercase;
	}
	.cas-q-answer {
		font-weight: 800;
		font-size: 0.95rem;
	}
	.cas-q.tone-yes .cas-q-answer {
		color: #0f7a52;
	}
	.cas-q.tone-no .cas-q-answer {
		color: #b4462f;
	}
	.cas-q.tone-shrink .cas-q-answer {
		color: var(--orange);
	}
	.cas-q-question {
		margin: 0 0 0.45rem;
		font-weight: 600;
		color: var(--ink);
		font-size: 0.98rem;
		line-height: 1.4;
	}
	.cas-q-why {
		margin: 0;
		color: var(--muted);
		font-size: 0.88rem;
		line-height: 1.45;
	}

	.cas-method-grid,
	.cas-support-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 0.85rem;
		margin-top: 0.9rem;
	}
	.cas-method,
	.cas-support {
		border: 1px solid var(--line);
		border-radius: 12px;
		padding: 1rem 1.1rem;
		background: rgba(255, 253, 248, 0.6);
	}
	.cas-method h3,
	.cas-support h3 {
		margin: 0 0 0.4rem;
		font-size: 1.02rem;
	}
	.cas-method p,
	.cas-support p {
		margin: 0;
		color: var(--muted);
		font-size: 0.92rem;
		line-height: 1.5;
	}
	.cas-support-tag {
		display: inline-block;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.68rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		padding: 0.2rem 0.5rem;
		border-radius: 999px;
		margin-bottom: 0.55rem;
	}
	.kind-positive .cas-support-tag {
		background: rgba(20, 150, 100, 0.12);
		color: #0f7a52;
	}
	.kind-negative .cas-support-tag {
		background: rgba(180, 70, 47, 0.12);
		color: #b4462f;
	}
	.kind-context .cas-support-tag {
		background: rgba(200, 120, 20, 0.14);
		color: #9a5c00;
	}

	.cas-table-wrap {
		overflow-x: auto;
		margin: 0.5rem 0 0.75rem;
	}
	.cas-table {
		border-collapse: collapse;
		width: 100%;
		min-width: 480px;
		font-size: 0.94rem;
	}
	.cas-table th,
	.cas-table td {
		border-bottom: 1px solid var(--line);
		padding: 0.55rem 0.7rem;
		text-align: right;
	}
	.cas-table thead th {
		color: var(--muted);
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		font-weight: 700;
	}
	.cas-table th[scope='row'],
	.cas-table thead th:first-child {
		text-align: left;
	}
	.cas-table tbody th[scope='row'] {
		font-weight: 600;
		color: var(--ink);
	}
	.cas-table tr.is-highlight {
		background: rgba(20, 150, 100, 0.08);
	}
	.cas-table tr.is-highlight td,
	.cas-table tr.is-highlight th {
		color: #0f7a52;
		font-weight: 700;
	}

	.cas-note {
		background: rgba(16, 23, 34, 0.04);
		border-radius: 12px;
		padding: 0.85rem 1rem;
		color: var(--muted);
		font-size: 0.95rem;
		line-height: 1.55;
		max-width: 860px;
	}
	.cas-note strong {
		color: var(--ink);
	}

	.cas-takeaway ul {
		display: grid;
		gap: 0.7rem;
		margin: 0.5rem 0 0;
		padding-left: 1.1rem;
	}
	.cas-takeaway li {
		color: var(--muted);
		font-size: clamp(1rem, 1.5vw, 1.1rem);
		line-height: 1.55;
		max-width: 860px;
	}
	.cas-takeaway strong {
		color: var(--ink);
	}
</style>
