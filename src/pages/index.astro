---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="hero">
				<p class="eyebrow">Personal site</p>
				<h1>Raghavan Muthuregunathan</h1>
				<p class="lede">
					I build practical software, learn in public, and turn ideas into things people can use.
				</p>
				<div class="actions">
					<a class="button primary" href="/about">About me</a>
					<a class="button secondary" href="https://github.com/Raghavan1988">GitHub</a>
				</div>
			</section>

			<section class="focus-grid" aria-label="Areas of focus">
				<article>
					<h2>Build</h2>
					<p>
						I care about turning fuzzy ideas into working products with clear scope, useful defaults,
						and thoughtful execution.
					</p>
				</article>
				<article>
					<h2>Learn</h2>
					<p>
						I like using real projects as the classroom: exploring tools, documenting decisions, and
						improving through steady iteration.
					</p>
				</article>
				<article>
					<h2>Ship</h2>
					<p>
						My bias is toward momentum: small releases, fast feedback, and making work visible enough
						to get better.
					</p>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>
