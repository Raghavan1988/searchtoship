---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const projects = [
	{
		area: 'Evals',
		title: 'SAGE: Scalable AI Governance & Evaluation',
		done:
			'Co-authored a KDD-accepted evaluation framework that turns calibrated human product judgment into scalable policy-aligned surrogate judges for industrial search.',
		link: 'https://arxiv.org/abs/2602.07840',
		linkLabel: 'arXiv 2602.07840',
	},
	{
		area: 'Semantic Search',
		title: 'A Unified Structured Query Understanding Framework for Industrial Semantic Search',
		done:
			'Co-authored a deployed structured query understanding system that consolidates search interpretation into schema-constrained generation with scalable annotation and evaluation.',
		link: 'https://arxiv.org/abs/2605.27441',
		linkLabel: 'arXiv 2605.27441',
	},
	{
		area: 'Mechanistic Interpretability',
		title: 'LatentGPT / LatentWorldsGPT',
		done:
			'Built small-transformer experiments across maze and HTTP domains to test when residual-stream features are recoverable, useful, or merely carried through by architecture.',
		link: 'https://github.com/Raghavan1988/LatentWorldsGPT',
		linkLabel: 'GitHub',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="intro">
				<p class="eyebrow">Search, evals, retrieval, interpretability</p>
				<h1>Raghavan Muthuregunathan</h1>
				<p class="lede">
					Research-minded engineer building systems that connect model behavior, product judgment,
					and production constraints.
				</p>
			</section>

			<section class="project-list" aria-label="Selected projects">
				{
					projects.map((project) => (
						<article class="project-card">
							<p class="project-area">{project.area}</p>
							<h2>{project.title}</h2>
							<p>{project.done}</p>
							<a href={project.link}>{project.linkLabel}</a>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
